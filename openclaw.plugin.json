{
  "id": "openclaw-smart-search",
  "name": "Smart Search & Browser Automation",
  "description": "Zero-token, Cloudflare-bypassing Stealth Search and dynamic Browser CDP controller plugin. Supports both headless Chromium and real Chrome debug mode.",
  "version": "1.1.0",
  "enabledByDefault": true,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "capabilityTags": [
    "search",
    "browser",
    "stealth",
    "cloudflare-bypass",
    "playwright",
    "chromium"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultProfile": {
        "type": "string",
        "description": "Default browser profile for CDP navigation.",
        "default": "host-chrome"
      }
    },
    "additionalProperties": false
  },
  "docker": {
    "apt": ["xvfb", "socat"],
    "npmGlobal": ["playwright"],
    "postInstallScripts": [
      "npx playwright install chromium --with-deps",
      "ln -f -s /root/.cache/ms-playwright/chromium-*/chrome-linux*/chrome /usr/bin/google-chrome 2>/dev/null || true"
    ],
    "extraHosts": ["host.docker.internal:host-gateway"],
    "entrypoint": {
      "description": "Auto-detect host Chrome or start local headless Chromium",
      "position": "before-gateway"
    }
  },
  "skills": [],
  "providers": [],
  "channels": []
}
